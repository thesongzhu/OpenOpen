+@Test
+func openOpenRPCRejectsAdvancedAndWidenedSendSurface() async throws {
+  let databaseURL = FileManager.default.temporaryDirectory
+    .appendingPathComponent("openopen-imsg-test-\(UUID().uuidString).sqlite")
+  _ = try Connection(databaseURL.path)
+  defer { try? FileManager.default.removeItem(at: databaseURL) }
+  let store = try MessageStore(path: databaseURL.path)
+  let output = OpenOpenTestRPCOutput()
+  let server = RPCServer(store: store, verbose: false, output: output)
+
+  await server.handleLineForTesting(
+    #"{"jsonrpc":"2.0","id":"advanced","method":"message.delete","params":{"guid":"x"}}"#)
+  await server.handleLineForTesting(
+    #"{"jsonrpc":"2.0","id":"auto","method":"send","params":{"chat_id":1,"text":"x"}}"#)
+  await server.handleLineForTesting(
+    #"{"jsonrpc":"2.0","id":"bridge","method":"send","params":{"chat_id":1,"text":"x","service":"auto","transport":"bridge"}}"#)
+  await server.handleLineForTesting(
+    #"{"jsonrpc":"2.0","id":"file","method":"send","params":{"chat_id":1,"text":"x","service":"auto","transport":"applescript","file":"/tmp/x"}}"#)
+  await server.handleLineForTesting(
+    #"{"jsonrpc":"2.0","method":"send","params":{"chat_id":1,"text":"x","service":"auto","transport":"applescript"}}"#)
+  await server.handleLineForTesting(
+    #"{"id":"legacy","method":"chats.list","params":{}}"#)
+  await server.handleLineForTesting(
+    #"{"jsonrpc":"2.0","id":"bool","method":"messages.history","params":{"chat_id":true}}"#)
+
+  #expect(output.responses.isEmpty)
+  let codes = output.errors.compactMap { payload in
+    (payload["error"] as? [String: Any])?["code"] as? Int
+  }
+  #expect(codes == [-32601, -32602, -32602, -32602, -32600, -32600, -32602])
+}
