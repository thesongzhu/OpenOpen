+
+@Test
+func openOpenSendObservationWaitsForTheWholeWindowAndSendsOnce() {
+  let first = OpenOpenSentMessage(rowID: 101, guid: "provider-guid-1")
+  let second = OpenOpenSentMessage(rowID: 102, guid: "provider-guid-2")
+  var clock = Date(timeIntervalSince1970: 0)
+  var sends = 0
+  var polls = 0
+  let ambiguous = openOpenSendAndObserve(
+    window: 0.1,
+    send: { sends += 1 },
+    poll: {
+      polls += 1
+      return polls < 3 ? [first] : [first, second]
+    },
+    now: { clock },
+    sleep: { clock.addTimeInterval($0) })
+  #expect(ambiguous == nil)
+  #expect(sends == 1)
+  #expect(polls >= 3)
+  #expect(clock >= Date(timeIntervalSince1970: 0.1))
+
+  clock = Date(timeIntervalSince1970: 0)
+  sends = 0
+  polls = 0
+  let unique = openOpenSendAndObserve(
+    window: 0.1,
+    send: { sends += 1 },
+    poll: {
+      polls += 1
+      return [first]
+    },
+    now: { clock },
+    sleep: { clock.addTimeInterval($0) })
+  #expect(unique == first)
+  #expect(sends == 1)
+  #expect(polls >= 3)
+  #expect(clock >= Date(timeIntervalSince1970: 0.1))
+}
