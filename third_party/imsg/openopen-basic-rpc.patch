diff --git a/Sources/IMsgCore/OpenOpenBasicMessageSender.swift b/Sources/IMsgCore/OpenOpenBasicMessageSender.swift
new file mode 100644
index 0000000..4f32bc6
--- /dev/null
+++ b/Sources/IMsgCore/OpenOpenBasicMessageSender.swift
@@ -0,0 +1,55 @@
+import Foundation
+
+#if os(macOS)
+  import Carbon
+#endif
+
+public struct OpenOpenBasicMessageSender {
+  public init() {}
+
+  public func send(text: String, chatIdentifier: String) throws {
+    let text = text.trimmingCharacters(in: .whitespacesAndNewlines)
+    let chatIdentifier = chatIdentifier.trimmingCharacters(in: .whitespacesAndNewlines)
+    guard !text.isEmpty, !chatIdentifier.isEmpty else {
+      throw IMsgError.invalidChatTarget("OpenOpen requires non-empty text and selected chat")
+    }
+    #if os(macOS)
+      let source = """
+        on run argv
+            set theMessage to item 1 of argv
+            set chatId to item 2 of argv
+            tell application "Messages"
+                set targetChat to chat id chatId
+                send theMessage to targetChat
+            end tell
+        end run
+        """
+      guard let script = NSAppleScript(source: source) else {
+        throw IMsgError.appleScriptFailure("Unable to compile AppleScript")
+      }
+      var errorInfo: NSDictionary?
+      let event = NSAppleEventDescriptor(
+        eventClass: AEEventClass(kASAppleScriptSuite),
+        eventID: AEEventID(kASSubroutineEvent),
+        targetDescriptor: nil,
+        returnID: AEReturnID(kAutoGenerateReturnID),
+        transactionID: AETransactionID(kAnyTransactionID)
+      )
+      event.setParam(
+        NSAppleEventDescriptor(string: "run"), forKeyword: AEKeyword(keyASSubroutineName))
+      let arguments = NSAppleEventDescriptor.list()
+      arguments.insert(NSAppleEventDescriptor(string: text), at: 1)
+      arguments.insert(NSAppleEventDescriptor(string: chatIdentifier), at: 2)
+      event.setParam(arguments, forKeyword: keyDirectObject)
+      script.executeAppleEvent(event, error: &errorInfo)
+      if let errorInfo {
+        let message =
+          (errorInfo[NSAppleScript.errorMessage] as? String) ?? "Unknown AppleScript error"
+        throw IMsgError.appleScriptFailure(message)
+      }
+    #else
+      throw IMsgError.appleScriptFailure(
+        "Sending requires Messages.app automation and is only supported on macOS.")
+    #endif
+  }
+}
