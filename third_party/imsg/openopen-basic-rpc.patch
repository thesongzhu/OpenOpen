+
+@testable import IMsgCore
+@testable import imsg
+
+final class OpenOpenTestRPCOutput: RPCOutput, @unchecked Sendable {
+  private let lock = NSLock()
+  private(set) var responses: [[String: Any]] = []
+  private(set) var errors: [[String: Any]] = []
+
+  func sendResponse(id: Any, result: Any) {
+    lock.withLock { responses.append(["id": id, "result": result]) }
+  }
+
+  func sendError(id: Any?, error: RPCError) {
+    lock.withLock { errors.append(["id": id ?? NSNull(), "error": error.asDictionary()]) }
+  }
+
+  func sendNotification(method: String, params: Any) {
+    _ = method
+    _ = params
+  }
+}
