diff --git a/Sources/imsg/OpenOpenBasicRPCServer.swift b/Sources/imsg/OpenOpenBasicRPCServer.swift
new file mode 100644
index 0000000..f7c6e4d
--- /dev/null
+++ b/Sources/imsg/OpenOpenBasicRPCServer.swift
@@ -0,0 +1,472 @@
+import Foundation
+import IMsgCore
+
+protocol RPCOutput: Sendable {
+  func sendResponse(id: Any, result: Any)
+  func sendError(id: Any?, error: RPCError)
+  func sendNotification(method: String, params: Any)
+}
+
+let kSupportedRPCMethods: [String] = [
+  "chats.list",
+  "messages.history",
+  "watch.subscribe",
+  "watch.unsubscribe",
+  "send",
+  "message.send_status",
+]
+
+final class RPCWriter: RPCOutput, Sendable {
+  func sendResponse(id: Any, result: Any) {
+    send(["jsonrpc": "2.0", "id": id, "result": result])
+  }
+
+  func sendError(id: Any?, error: RPCError) {
+    send([
+      "jsonrpc": "2.0",
+      "id": id ?? NSNull(),
+      "error": error.asDictionary(),
+    ])
+  }
+
+  func sendNotification(method: String, params: Any) {
+    send(["jsonrpc": "2.0", "method": method, "params": params])
+  }
+
+  private func send(_ value: Any) {
+    do {
+      let data = try JSONSerialization.data(withJSONObject: value, options: [])
+      guard let line = String(data: data, encoding: .utf8) else { throw RPCWriteError() }
+      StdoutWriter.writeLine(line)
+    } catch {
+      StdoutWriter.writeLine(
+        #"{"jsonrpc":"2.0","error":{"code":-32603,"message":"write failed"}}"#)
+    }
+  }
+
+  private struct RPCWriteError: Error {}
+}
+
+struct RPCError: Error {
+  let code: Int
+  let message: String
+  let data: String?
+
+  static func parseError(_ data: String) -> RPCError {
+    RPCError(code: -32700, message: "Parse error", data: data)
+  }
+
+  static func invalidRequest(_ data: String) -> RPCError {
+    RPCError(code: -32600, message: "Invalid Request", data: data)
+  }
+
+  static func methodNotFound(_ method: String) -> RPCError {
+    RPCError(code: -32601, message: "Method not found", data: method)
+  }
+
+  static func invalidParams(_ data: String) -> RPCError {
+    RPCError(code: -32602, message: "Invalid params", data: data)
+  }
+
+  static func internalError(_ data: String) -> RPCError {
+    RPCError(code: -32603, message: "Internal error", data: data)
+  }
+
+  func asDictionary() -> [String: Any] {
+    var value: [String: Any] = ["code": code, "message": message]
+    if let data { value["data"] = data }
+    return value
+  }
+}
+
+actor OpenOpenSubscriptionStore {
+  private var nextID = 1
+  private var tasks: [Int: Task<Void, Never>] = [:]
+
+  func allocate() -> Int {
+    let value = nextID
+    nextID += 1
+    return value
+  }
+
+  func insert(_ task: Task<Void, Never>, id: Int) { tasks[id] = task }
+  func remove(_ id: Int) -> Task<Void, Never>? { tasks.removeValue(forKey: id) }
+
+  func cancelAll() {
+    for task in tasks.values { task.cancel() }
+    tasks.removeAll()
+  }
+}
+
+struct OpenOpenSentMessage: Sendable, Hashable {
+  let rowID: Int64
+  let guid: String
+}
+
+func openOpenSendAndObserve(
+  window: TimeInterval,
+  send: () throws -> Void,
+  poll: () throws -> [OpenOpenSentMessage],
+  now: () -> Date = Date.init,
+  sleep: (TimeInterval) -> Void = Thread.sleep
+) rethrows -> OpenOpenSentMessage? {
+  try send()
+  let deadline = now().addingTimeInterval(window)
+  var candidates = Set<OpenOpenSentMessage>()
+  var ambiguous = false
+  while true {
+    candidates.formUnion(try poll())
+    if candidates.count > 1 { ambiguous = true }
+    let remaining = deadline.timeIntervalSince(now())
+    if remaining <= 0 { break }
+    sleep(min(0.05, remaining))
+  }
+  guard !ambiguous, candidates.count == 1 else { return nil }
+  return candidates.first
+}
+
+final class RPCServer {
+  private let store: MessageStore
+  private let watcher: MessageWatcher
+  private let output: RPCOutput
+  private let subscriptions = OpenOpenSubscriptionStore()
+  private let sendMessage: @Sendable (String, String, Int64) throws -> OpenOpenSentMessage?
+
+  init(
+    store: MessageStore,
+    verbose: Bool,
+    output: RPCOutput = RPCWriter(),
+    sendMessage: (@Sendable (String, String, Int64) throws -> OpenOpenSentMessage?)? = nil
+  ) {
+    self.store = store
+    self.watcher = MessageWatcher(store: store)
+    self.output = output
+    self.sendMessage = sendMessage ?? { text, chatIdentifier, chatID in
+      let highWater = try store.maxRowID()
+      return try openOpenSendAndObserve(
+        window: 2,
+        send: {
+          try OpenOpenBasicMessageSender().send(text: text, chatIdentifier: chatIdentifier)
+        },
+        poll: {
+          try store.messages(chatID: chatID, limit: 50).compactMap { message in
+            guard message.rowID > highWater, message.isFromMe, message.text == text,
+              !message.guid.isEmpty
+            else { return nil }
+            return OpenOpenSentMessage(rowID: message.rowID, guid: message.guid)
+          }
+        }
+      )
+    }
+    _ = verbose
+  }
+
+  func run() async throws {
+    while let line = readLine() {
+      let trimmed = line.trimmingCharacters(in: .whitespacesAndNewlines)
+      if !trimmed.isEmpty { await handleLine(trimmed) }
+    }
+    await subscriptions.cancelAll()
+  }
+
+  func handleLineForTesting(_ line: String) async { await handleLine(line) }
+
+  private func handleLine(_ line: String) async {
+    let request: RPCRequest
+    switch RPCRequestParser.parse(line) {
+    case .success(let parsed): request = parsed
+    case .failure(let failure):
+      output.sendError(id: failure.id, error: failure.error)
+      return
+    }
+    guard request.paramsAreNamed else {
+      output.sendError(id: request.id, error: .invalidParams("params must be an object"))
+      return
+    }
+    if request.method == "send" && (request.id == nil || request.id is NSNull) {
+      output.sendError(id: request.id, error: .invalidRequest("send requires a request id"))
+      return
+    }
+    do {
+      switch request.method {
+      case "chats.list": try handleChatsList(id: request.id, params: request.params)
+      case "messages.history": try handleHistory(id: request.id, params: request.params)
+      case "watch.subscribe": try await handleSubscribe(id: request.id, params: request.params)
+      case "watch.unsubscribe": try await handleUnsubscribe(id: request.id, params: request.params)
+      case "send": try handleSend(id: request.id, params: request.params)
+      case "message.send_status": try handleSendStatus(id: request.id, params: request.params)
+      default: output.sendError(id: request.id, error: .methodNotFound(request.method))
+      }
+    } catch let error as RPCError {
+      output.sendError(id: request.id, error: error)
+    } catch {
+      output.sendError(id: request.id, error: .internalError(error.localizedDescription))
+    }
+  }
+
+  private func handleChatsList(id: Any?, params: [String: Any]) throws {
+    try requireOnly(params, keys: ["limit", "unread_only"])
+    let limit = try boundedInteger(params["limit"], default: 20, range: 1...200, name: "limit")
+    let unreadOnly = try optionalBoolean(params["unread_only"], default: false, name: "unread_only")
+    guard !unreadOnly || store.supportsUnreadState else {
+      throw RPCError.invalidParams("unread_only is unavailable")
+    }
+    let chats = try store.listChats(limit: limit, unreadOnly: unreadOnly)
+    let values = try chats.map { chat -> [String: Any] in
+      let info = try store.chatInfo(chatID: chat.id)
+      let identifier = info?.identifier ?? chat.identifier
+      let guid = info?.guid ?? ""
+      var value: [String: Any] = [
+        "id": chat.id,
+        "identifier": identifier,
+        "guid": guid,
+        "name": info?.name ?? chat.name,
+        "service": info?.service ?? chat.service,
+        "last_message_at": rpcDate(chat.lastMessageAt),
+        "participants": try store.participants(chatID: chat.id),
+        "is_group": isGroup(identifier: identifier, guid: guid),
+      ]
+      if let unreadCount = chat.unreadCount { value["unread_count"] = unreadCount }
+      return value
+    }
+    respond(id: id, result: ["chats": values])
+  }
+
+  private func handleHistory(id: Any?, params: [String: Any]) throws {
+    try requireOnly(params, keys: ["chat_id", "limit", "attachments"])
+    let chatID = try positiveInt64(params["chat_id"], name: "chat_id")
+    let limit = try boundedInteger(params["limit"], default: 50, range: 1...200, name: "limit")
+    guard try optionalBoolean(params["attachments"], default: false, name: "attachments") == false
+    else { throw RPCError.invalidParams("attachments are unavailable") }
+    let values = try store.messages(chatID: chatID, limit: limit).map { message in
+      try messagePayload(message)
+    }
+    respond(id: id, result: ["messages": values])
+  }
+
+  private func handleSubscribe(id: Any?, params: [String: Any]) async throws {
+    try requireOnly(
+      params,
+      keys: ["chat_id", "since_rowid", "attachments", "include_reactions", "debounce_ms"])
+    let chatID = try positiveInt64(params["chat_id"], name: "chat_id")
+    let sinceRowID = try optionalNonnegativeInt64(params["since_rowid"], name: "since_rowid")
+    guard try optionalBoolean(params["attachments"], default: false, name: "attachments") == false,
+      try optionalBoolean(params["include_reactions"], default: false, name: "include_reactions")
+        == false
+    else { throw RPCError.invalidParams("attachments and reactions are unavailable") }
+    let debounce = try boundedInteger(
+      params["debounce_ms"], default: 500, range: 50...5_000, name: "debounce_ms")
+    let subscription = await subscriptions.allocate()
+    let watcher = watcher
+    let output = output
+    let store = store
+    let task = Task {
+      do {
+        let configuration = MessageWatcherConfiguration(
+          debounceInterval: Double(debounce) / 1_000,
+          fallbackPollInterval: 5,
+          batchLimit: 100,
+          includeReactions: false
+        )
+        for try await message in watcher.stream(
+          chatID: chatID,
+          sinceRowID: sinceRowID,
+          configuration: configuration
+        ) {
+          if Task.isCancelled { return }
+          output.sendNotification(
+            method: "message",
+            params: [
+              "subscription": subscription,
+              "message": try openOpenMessagePayload(message, store: store),
+            ]
+          )
+        }
+      } catch {
+        output.sendNotification(
+          method: "error",
+          params: ["subscription": subscription, "error": ["message": error.localizedDescription]]
+        )
+      }
+    }
+    await subscriptions.insert(task, id: subscription)
+    respond(id: id, result: ["subscription": subscription])
+  }
+
+  private func handleUnsubscribe(id: Any?, params: [String: Any]) async throws {
+    try requireOnly(params, keys: ["subscription"])
+    let subscription = try boundedInteger(
+      params["subscription"], default: 0, range: 1...Int.max, name: "subscription")
+    if let task = await subscriptions.remove(subscription) { task.cancel() }
+    respond(id: id, result: ["ok": true])
+  }
+
+  private func handleSend(id: Any?, params: [String: Any]) throws {
+    try requireOnly(params, keys: ["chat_id", "text", "service", "transport"])
+    let chatID = try positiveInt64(params["chat_id"], name: "chat_id")
+    guard let text = params["text"] as? String,
+      !text.trimmingCharacters(in: .whitespacesAndNewlines).isEmpty
+    else { throw RPCError.invalidParams("text is required") }
+    guard text.utf8.count <= 32 * 1_024, !text.utf8.contains(0) else {
+      throw RPCError.invalidParams("text exceeds the OpenOpen bound")
+    }
+    guard (params["service"] as? String) == "auto",
+      (params["transport"] as? String) == "applescript"
+    else { throw RPCError.invalidParams("OpenOpen requires service=auto and transport=applescript") }
+    guard let info = try store.chatInfo(chatID: chatID), !info.guid.isEmpty else {
+      throw RPCError.invalidParams("unknown chat_id or missing chat GUID")
+    }
+    let sent = try sendMessage(text, info.guid, chatID)
+    respond(id: id, result: openOpenSendResult(chatGUID: info.guid, sent: sent))
+  }
+
+  private func handleSendStatus(id: Any?, params: [String: Any]) throws {
+    try requireOnly(params, keys: ["guid"])
+    guard let guid = params["guid"] as? String,
+      !guid.trimmingCharacters(in: .whitespacesAndNewlines).isEmpty,
+      guid.utf8.count <= 256,
+      !guid.utf8.contains(0)
+    else { throw RPCError.invalidParams("guid is required") }
+    let checkedAt = Date()
+    guard let status = try store.messageSendStatus(guid: guid) else {
+      respond(
+        id: id,
+        result: [
+          "ok": true,
+          "guid": guid,
+          "send_state": MessageSendState.pending.rawValue,
+          "service": NSNull(),
+          "checked_at": rpcDate(checkedAt),
+          "status_fields": NSNull(),
+        ])
+      return
+    }
+    var value: [String: Any] = [
+      "ok": true,
+      "guid": status.guid,
+      "send_state": status.state.rawValue,
+      "service": status.service.isEmpty ? NSNull() : status.service,
+      "checked_at": rpcDate(checkedAt),
+      "status_fields": [
+        "is_sent": status.isSent,
+        "is_delivered": status.isDelivered,
+        "is_finished": status.isFinished,
+        "error": status.error,
+        "date_delivered": status.dateDelivered.map(rpcDate) ?? NSNull(),
+        "date_read": status.dateRead.map(rpcDate) ?? NSNull(),
+        "is_delayed": status.isDelayed,
+        "is_prepared": status.isPrepared,
+        "is_pending_satellite_send": status.isPendingSatelliteSend,
+        "was_downgraded": status.wasDowngraded,
+      ],
+    ]
+    if let deliveredAt = status.dateDelivered { value["delivered_at"] = rpcDate(deliveredAt) }
+    respond(id: id, result: value)
+  }
+
+  private func messagePayload(_ message: Message) throws -> [String: Any] {
+    try openOpenMessagePayload(message, store: store)
+  }
+
+  private func respond(id: Any?, result: Any) {
+    guard let id else { return }
+    output.sendResponse(id: id, result: result)
+  }
+}
+
+func openOpenSendResult(chatGUID: String, sent: OpenOpenSentMessage?) -> [String: Any] {
+  var result: [String: Any] = [
+    "ok": true,
+    "transport": "applescript",
+    "chat_guid": chatGUID,
+  ]
+  if let sent {
+    result["id"] = sent.rowID
+    result["guid"] = sent.guid
+    result["message_id"] = sent.guid
+  }
+  return result
+}
+
+private func openOpenMessagePayload(_ message: Message, store: MessageStore) throws -> [String: Any] {
+  let info = try store.chatInfo(chatID: message.chatID)
+  let identifier = info?.identifier ?? ""
+  let guid = info?.guid ?? ""
+  var value: [String: Any] = [
+    "id": message.rowID,
+    "chat_id": message.chatID,
+    "chat_identifier": identifier,
+    "chat_guid": guid,
+    "chat_name": info?.name ?? "",
+    "participants": try store.participants(chatID: message.chatID),
+    "is_group": isGroup(identifier: identifier, guid: guid),
+    "guid": message.guid,
+    "sender": message.sender,
+    "is_from_me": message.isFromMe,
+    "text": message.text,
+    "created_at": rpcDate(message.date),
+  ]
+  if let reply = message.replyToGUID { value["reply_to_guid"] = reply }
+  if let text = message.replyToText { value["reply_to_text"] = text }
+  if let sender = message.replyToSender { value["reply_to_sender"] = sender }
+  if let callerID = message.destinationCallerID { value["destination_caller_id"] = callerID }
+  if let isRead = message.isRead { value["is_read"] = isRead }
+  if let dateRead = message.dateRead { value["date_read"] = rpcDate(dateRead) }
+  return value
+}
+
+private func requireOnly(_ params: [String: Any], keys: Set<String>) throws {
+  let unexpected = Set(params.keys).subtracting(keys)
+  guard unexpected.isEmpty else {
+    throw RPCError.invalidParams("unsupported params: \(unexpected.sorted().joined(separator: ","))")
+  }
+}
+
+private func boundedInteger(
+  _ value: Any?,
+  default defaultValue: Int,
+  range: ClosedRange<Int>,
+  name: String
+) throws -> Int {
+  let parsed: Int
+  if value == nil { parsed = defaultValue } else if !(value is Bool),
+    let number = value as? NSNumber
+  {
+    parsed = number.intValue
+  } else { throw RPCError.invalidParams("\(name) must be an integer") }
+  guard range.contains(parsed) else { throw RPCError.invalidParams("\(name) is outside the bound") }
+  return parsed
+}
+
+private func positiveInt64(_ value: Any?, name: String) throws -> Int64 {
+  guard !(value is Bool), let number = value as? NSNumber, number.int64Value > 0 else {
+    throw RPCError.invalidParams("\(name) must be positive")
+  }
+  return number.int64Value
+}
+
+private func optionalNonnegativeInt64(_ value: Any?, name: String) throws -> Int64? {
+  guard let value else { return nil }
+  guard !(value is Bool), let number = value as? NSNumber, number.int64Value >= 0 else {
+    throw RPCError.invalidParams("\(name) must be non-negative")
+  }
+  return number.int64Value
+}
+
+private func optionalBoolean(_ value: Any?, default defaultValue: Bool, name: String) throws -> Bool {
+  guard let value else { return defaultValue }
+  guard let boolean = value as? Bool else {
+    throw RPCError.invalidParams("\(name) must be a boolean")
+  }
+  return boolean
+}
+
+private func isGroup(identifier: String, guid: String) -> Bool {
+  guid.contains(";+;") || identifier.contains(";+;")
+}
+
+private func rpcDate(_ date: Date) -> String {
+  let formatter = ISO8601DateFormatter()
+  formatter.formatOptions = [.withInternetDateTime, .withFractionalSeconds]
+  return formatter.string(from: date)
+}
